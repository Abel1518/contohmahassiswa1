{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/wisuda/mahasiswa",
      "dest": "/api/wisuda/api_mahasiswa.php"
    },
    {
      "src": "/wisuda/periode",
      "dest": "/api/wisuda/api_periode.php"
    },
    {
      "src": "/wisuda/staf",
      "dest": "/api/wisuda/api_staf.php"
    },
    {
      "src": "/wisuda/pendaftaran",
      "dest": "/api/wisuda/api_pendaftaran.php"
    },

    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}
