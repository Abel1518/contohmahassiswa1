{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "api1/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/koneksi.php", "dest": "/api/koneksi.php" },
    { "src": "/(.*\\.php)", "dest": "/api/$1" },

    { "src": "/mahasiswa", "dest": "/api1/api_mahasiswa.php" },
    { "src": "/periode", "dest": "/api1/api_periode.php" },
    { "src": "/staf", "dest": "/api1/api_staf.php" },
    { "src": "/pendaftaran", "dest": "/api1/api_pendaftaran.php" }
  ]
}
